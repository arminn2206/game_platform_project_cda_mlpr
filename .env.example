# Copy this file to ".env" and fill in your own values.
# Never commit the real ".env" file to GitHub.

# Get a free key at https://rawg.io/apidocs
RAWG_API_KEY=your_rawg_api_key_here

# Path to the SQLite database file (relative to project root)
DB_PATH=db/game_platform.db

# Get a free key at https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your_steam_api_key_here

# Country code used for Steam price lookups (ISO 3166-1 alpha-2)
STEAM_COUNTRY_CODE=us
